---
import Base from "../../layouts/Base.astro";
import AppStoreBadge from "../../components/AppStoreBadge.astro";

const pillars = [
  {
    title: "Health first",
    body: "Calm reminders and a Posture Coach that helps you move more without nagging.",
  },
  {
    title: "Comfort & ergonomics",
    body: "Tap, shortcut, or voice — no more holding a button on the side of your desk.",
  },
  {
    title: "Native Mac feel",
    body: "Menu bar, SF Symbols, iCloud sync. Zero third-party dependencies.",
  },
  {
    title: "Privacy by design",
    body: "No account, no analytics, no servers. Bluetooth talks only to your desk.",
  },
];

type Cell = boolean | "—";
// Mirrors ProFeature.matrix in the DeskShift app — Free-first, then Pro-only,
// then lifetime parity. Titles and descriptions copied from the app.
const matrix: Array<{ feature: string; desc: string; free: Cell; pro: Cell }> = [
  { feature: "Multi-desk support", desc: "Pair every desk you use and switch between them in a tap.", free: true, pro: true },
  { feature: "Launch at login", desc: "DeskShift is ready the moment you sign in.", free: true, pro: true },
  { feature: "Auto-reconnect to your last desk", desc: "Walk up and you’re connected — no fiddling with Bluetooth.", free: true, pro: true },
  { feature: "iCloud sync across devices", desc: "Your desks and presets follow your Apple ID to every Mac.", free: true, pro: true },
  { feature: "Manual up / down (hold to move)", desc: "Hold to raise or lower, release to stop. Simple.", free: true, pro: true },
  { feature: "Sit and Stand memory positions", desc: "Two one-tap heights for the postures you use most.", free: true, pro: true },

  { feature: "Create your custom memory positions", desc: "Name and shape your day — sit, stand, lean, perch — with custom icons.", free: false, pro: true },
  { feature: "Desk-button double-tap gesture", desc: "Double-tap the physical button to fly to Sit or Stand.", free: false, pro: true },
  { feature: "Notifications to switch positions", desc: "A gentle nudge when you’ve been sitting too long.", free: false, pro: true },
  { feature: "Posture Coach automation", desc: "Custom intervals, a schedule, and auto-move on your terms.", free: false, pro: true },
  { feature: "Customize the menu bar", desc: "Show an icon, the live height, or both. Your bar, your call.", free: false, pro: true },
  { feature: "Live height in the menu bar", desc: "Glance up and see exactly where your desk is, in cm or inches.", free: false, pro: true },
  { feature: "Siri integration", desc: "“Hey Siri, move my desk to Standing.” That’s the whole thing.", free: false, pro: true },
  { feature: "Spotlight search", desc: "Type a position name into Spotlight and hit return.", free: false, pro: true },
  { feature: "Shortcuts app integration", desc: "Make your desk a step in any automation you dream up.", free: false, pro: true },
  { feature: "Global keyboard shortcuts", desc: "Jump to any position from anywhere in macOS — no clicking.", free: false, pro: true },

  { feature: "Lifetime Pro updates", desc: "Every Pro feature we add later stays unlocked for you. Forever.", free: "—", pro: true },
];
---

<Base
  title="DeskShift — Your desk, in the menu bar"
  description="A calm, Mac-native menu-bar app for IKEA IDÅSEN and Linak Bluetooth standing desks. One price. Lifetime."
>
  <!-- Hero -->
  <section class="space-y-6">
    <p class="text-sm font-medium tracking-wide text-(--color-accent)">
      DeskShift for macOS
    </p>
    <h1 class="text-4xl leading-tight font-semibold tracking-tight sm:text-5xl">
      Your desk, in the menu bar.<br />
      <span class="text-(--color-muted)">Move with a tap.</span>
    </h1>
    <p class="max-w-xl text-lg text-(--color-muted)">
      Helps you adjust your posture at the right time. Stay in flow.
    </p>

    <div class="flex flex-wrap items-center gap-4 pt-2">
      <AppStoreBadge />
      <a href="#features" class="text-sm">Learn more →</a>
    </div>

    <p class="pt-1 text-xs text-(--color-muted)">
      For IKEA IDÅSEN &amp; other Linak-based Bluetooth desks. macOS 26 or
      later.
    </p>
  </section>

  <!-- Pillars -->
  <section class="mt-20 grid gap-8 sm:grid-cols-2">
    {
      pillars.map((p) => (
        <div>
          <h3 class="text-base font-semibold tracking-tight">{p.title}</h3>
          <p class="mt-2 text-(--color-muted)">{p.body}</p>
        </div>
      ))
    }
  </section>

  <!-- Free vs Pro -->
  <section id="features" class="mt-20">
    <p class="text-2xl font-semibold tracking-tight sm:text-3xl">
      One price. One time. Yours forever.
    </p>
    <p class="mt-3 text-lg text-(--color-muted)">
      Every new install starts with a 14-day full-Pro trial — no card, no
      account.
    </p>

    <div class="mt-6 overflow-x-auto rounded-2xl border border-(--color-border)">
      <table class="w-full text-sm">
        <thead class="bg-(--color-bg) text-left">
          <tr>
            <th class="px-4 py-3 font-medium">Feature</th>
            <th class="px-4 py-3 text-center font-medium">Free</th>
            <th class="px-4 py-3 text-center font-medium">Pro</th>
          </tr>
        </thead>
        <tbody>
          {
            matrix.map((row) => (
              <tr class="border-t border-(--color-border)/60 align-top">
                <td class="px-4 py-3">
                  <div class="font-medium">{row.feature}</div>
                  <div class="mt-0.5 text-xs text-(--color-muted)">{row.desc}</div>
                </td>
                <td class="px-4 py-3 text-center">
                  {row.free === true ? "✓" : row.free === "—" ? "—" : ""}
                </td>
                <td class="px-4 py-3 text-center">
                  {row.pro === true ? "✓" : row.pro === "—" ? "—" : ""}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p class="mt-6 text-base">
      <span class="font-semibold">Pro is a one-time purchase — $19.99 USD.</span>
      No subscription, no upsells. Every Pro feature today, and every Pro
      feature added later, stays unlocked on every Mac signed in to your Apple
      ID.
    </p>
  </section>

  <!-- CTA -->
  <section class="mt-20 rounded-2xl border border-(--color-border) bg-(--color-surface) p-8 text-center">
    <h2 class="text-2xl font-semibold tracking-tight">Try DeskShift</h2>
    <p class="mx-auto mt-2 max-w-md text-(--color-muted)">
      Full Pro free for 14 days. No card. No account. No email.
    </p>
    <div class="mt-6 flex justify-center">
      <AppStoreBadge />
    </div>
  </section>
</Base>
