---
import Base from "../../layouts/Base.astro";

// The website contact form posts to the SAME Google Form the macOS app uses for
// in-app feedback (see DeskShift's `FeedbackForm.deskShift` /
// `FeedbackCategory.formValue`). One inbox for app + website. The form id and
// `entry.*` ids below mirror that config — keep them in step if the app's change.
const GOOGLE_FORM_ID =
  "1FAIpQLScPJSpkZXOJLsdh0yaLGP-q_6NLxzdpAvp2ziEjmPnoLnJW-g";
const FORM_ACTION = `https://docs.google.com/forms/d/e/${GOOGLE_FORM_ID}/formResponse`;

const ENTRY = {
  category: "entry.645832316",
  details: "entry.301068786",
  email: "entry.2137833322",
  appVersion: "entry.1120512372",
  build: "entry.1389019362",
  osType: "entry.1183756905",
  osVersion: "entry.1845982949",
  locale: "entry.273320308",
  subscription: "entry.280537996",
};

// The user-facing topic maps to one of the form's Category options
// ("Bug report (Something broken)" / "Feature request" / "Feature improvement" /
// "Other"). Every value
// here is a valid option, so Google never silently rejects the submission; the
// precise topic is also preserved verbatim in the Details field.
const TOPIC_TO_CATEGORY: Record<string, string> = {
  "Bug report": "Bug report (Something broken)",
  "Feature request": "Feature request",
  "Question about compatibility": "Other",
  "Purchase / refund / receipt": "Other",
  Other: "Other",
};

const faqs = [
  {
    q: "Which desks does DeskShift work with?",
    a: "Any standing desk based on the Linak Bluetooth protocol. The IKEA IDÅSEN line is the primary target. Other Linak-based desks generally work too, but compatibility is best-effort. If your desk has a Bluetooth dongle and a Linak controller, give it a try.",
  },
  {
    q: "Does DeskShift run on iPhone or iPad?",
    a: "No. DeskShift is macOS only at launch. macOS 26.2 or later is required.",
  },
  {
    q: "Do I need to sign in to iCloud?",
    a: "It's recommended, not required. With iCloud on, DeskShift syncs your desks, presets, and preferences across your Macs and anchors your 14-day Pro trial so it doesn't restart when you reinstall. Without iCloud, everything still works — your setup just stays local to that Mac and won't sync. Either way, your data lives in your own private container; I cannot see it.",
  },
  {
    q: "Is the trial automatic?",
    a: "Yes. Every new install gets full Pro features for 14 days. No card, no account, no email asked.",
  },
  {
    q: "How do I get a refund?",
    a: "Refunds are handled by Apple, not by me. Open Settings → Apple ID → Media & Purchases → Account Settings → Purchase History on your Mac, find DeskShift, and request a refund directly through Apple.",
  },
  {
    q: "Where can I report a bug or request a feature?",
    a: "Use the form below, or email binisor.ionut@gmail.com directly. I read every message.",
  },
];
---

<Base
  title="DeskShift — Support"
  description="Get help with DeskShift. FAQ, troubleshooting, and a direct line to the developer."
>
  <section class="space-y-4">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Support</h1>
    <p class="text-lg text-(--color-muted)">
      DeskShift is built by one person. Send a message and you'll hear back from
      me directly.
    </p>
  </section>

  <!-- FAQ -->
  <section class="mt-16">
    <h2 class="text-2xl font-semibold tracking-tight">Frequently asked</h2>
    <div class="mt-6 space-y-6">
      {
        faqs.map((item) => (
          <details class="group rounded-xl border border-(--color-border) bg-(--color-surface) px-5 py-4 [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex cursor-pointer items-start justify-between gap-4 list-none">
              <span class="font-medium">{item.q}</span>
              <span
                class="mt-1 text-(--color-muted) transition group-open:rotate-45"
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <p class="mt-3 text-(--color-muted)">{item.a}</p>
          </details>
        ))
      }
    </div>
  </section>

  <!-- Contact form -->
  <section class="mt-16">
    <h2 class="text-2xl font-semibold tracking-tight">Get in touch</h2>
    <p class="mt-2 text-(--color-muted)">
      Everything goes straight to my inbox. I usually reply within 1–2 business
      days.
    </p>

    <form
      id="contact-form"
      action={FORM_ACTION}
      method="POST"
      class="mt-8 space-y-5"
      data-entry-category={ENTRY.category}
      data-entry-details={ENTRY.details}
      data-entry-email={ENTRY.email}
      data-entry-app-version={ENTRY.appVersion}
      data-entry-build={ENTRY.build}
      data-entry-os-type={ENTRY.osType}
      data-entry-os-version={ENTRY.osVersion}
      data-entry-locale={ENTRY.locale}
      data-entry-subscription={ENTRY.subscription}
      data-topic-map={JSON.stringify(TOPIC_TO_CATEGORY)}
    >
      <!-- Honeypot: bots fill hidden fields; real users never see this. -->
      <input
        type="text"
        name="company"
        class="hidden"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />

      <label class="block">
        <span class="text-sm font-medium">What can I help with?</span>
        <select
          name="topic"
          class="mt-2 w-full rounded-xl border border-(--color-border) bg-(--color-surface) px-4 py-3 text-base outline-none transition focus:border-(--color-accent)"
        >
          <option>Bug report</option>
          <option>Feature request</option>
          <option>Question about compatibility</option>
          <option>Purchase / refund / receipt</option>
          <option>Other</option>
        </select>
      </label>

      <label class="block">
        <span class="text-sm font-medium">Message</span>
        <textarea
          name="message"
          rows="6"
          required
          class="mt-2 w-full rounded-xl border border-(--color-border) bg-(--color-surface) px-4 py-3 text-base outline-none transition focus:border-(--color-accent)"
        ></textarea>
      </label>

      <div class="grid gap-5 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium"
            >Your name
            <span class="font-normal text-(--color-muted)">(optional)</span></span
          >
          <input
            type="text"
            name="name"
            autocomplete="name"
            class="mt-2 w-full rounded-xl border border-(--color-border) bg-(--color-surface) px-4 py-3 text-base outline-none transition focus:border-(--color-accent)"
          />
        </label>
        <label class="block">
          <span class="text-sm font-medium"
            >Your email
            <span class="font-normal text-(--color-muted)">(optional)</span></span
          >
          <input
            type="email"
            name="email"
            autocomplete="email"
            class="mt-2 w-full rounded-xl border border-(--color-border) bg-(--color-surface) px-4 py-3 text-base outline-none transition focus:border-(--color-accent)"
          />
        </label>
      </div>

      <button
        type="submit"
        class="inline-flex items-center rounded-xl bg-(--color-accent) px-6 py-3 text-base font-medium text-white transition hover:opacity-90 disabled:opacity-60"
      >
        Send message
      </button>
    </form>

    <p class="mt-6 text-sm text-(--color-muted)">
      Your message is delivered through a private Google Form that only I can
      read — the same inbox the app's in-app feedback goes to. Prefer email? Write
      to <a href="mailto:binisor.ionut@gmail.com">binisor.ionut@gmail.com</a>.
    </p>
  </section>
</Base>

<script is:inline>
  (function () {
    const form = document.getElementById("contact-form");
    if (!form) return;

    const button = form.querySelector('button[type="submit"]');
    const d = form.dataset;
    const topicMap = JSON.parse(d.topicMap || "{}");

    function banner(text, ok) {
      const el = document.createElement("div");
      el.textContent = text;
      el.style.cssText =
        "position:fixed;top:1rem;left:50%;transform:translateX(-50%);color:#fff;padding:0.75rem 1.25rem;border-radius:0.75rem;font-size:0.95rem;z-index:50;box-shadow:0 8px 24px rgba(0,0,0,0.15);background:" +
        (ok ? "var(--color-accent)" : "#b00020");
      document.body.appendChild(el);
      setTimeout(() => el.remove(), 5000);
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      // Honeypot tripped — pretend success, send nothing.
      if (form.elements.company && form.elements.company.value) {
        banner("Thanks — your message is on its way.", true);
        form.reset();
        return;
      }

      const name = (form.elements.name.value || "").trim();
      const email = (form.elements.email.value || "").trim();
      const topic = form.elements.topic.value || "Other";
      const message = (form.elements.message.value || "").trim();

      const details =
        "[Sent from the binisor.com contact form]\n" +
        "Topic: " +
        topic +
        (name ? "\nName: " + name : "") +
        "\n\n" +
        message;

      const body = new URLSearchParams();
      body.append(d.entryCategory, topicMap[topic] || "Other");
      body.append(d.entryDetails, details);
      if (email) body.append(d.entryEmail, email);
      // Known channel facts (used to tell website rows from app rows). The rest
      // is genuinely unknown on the web, so send "-" rather than inferring it.
      body.append(d.entryAppVersion, "Website");
      body.append(d.entryOsType, "Web");
      body.append(d.entryBuild, "-");
      body.append(d.entryOsVersion, "-");
      body.append(d.entryLocale, navigator.language || "-");
      body.append(d.entrySubscription, "-");

      if (button) {
        button.disabled = true;
        button.textContent = "Sending…";
      }

      try {
        // Google Forms sends no CORS headers, so we can't read the response —
        // post no-cors (fire-and-forget) and optimistically confirm success.
        await fetch(form.action, { method: "POST", mode: "no-cors", body });
        banner("Thanks — your message is on its way.", true);
        form.reset();
      } catch {
        banner(
          "Couldn't send — please email binisor.ionut@gmail.com instead.",
          false
        );
      } finally {
        if (button) {
          button.disabled = false;
          button.textContent = "Send message";
        }
      }
    });
  })();
</script>
